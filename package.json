{
  "name": "vagas-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#root/*": "./src/*",
    "#bots/*": "./apps/bots/src/*",
    "#api/*": "./apps/api/src/*",
    "#core/*": "./packages/core/*"
  },
  "scripts": {
    "start": "tsx apps/bots/src/index.js",
    "bots": "tsx apps/bots/src/index.js",
    "dev:bots": "tsx --watch apps/bots/src/index.js",
    "dev:scraper": "tsx --watch apps/worker-scraper/src/index.ts",
    "dev": "npx concurrently -n \"BOTS,SCRAPER\" -c \"blue,green\" \"npm run dev:bots\" \"npm run dev:scraper\"",
    "api": "node apps/api/src/index.js",
    "worker": "tsx apps/worker-scraper/src/index.ts",
    "scrape": "tsx apps/worker-scraper/src/index.ts",
    "audit:gupy": "tsx scripts/audit-gupy.ts",
    "audit:remotar": "tsx scripts/audit-remotar.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "protobufjs": "^7.5.5"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "cheerio": "^1.2.0",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "link-preview-js": "^3.0.5",
    "mongoose": "^9.6.0",
    "p-limit": "^7.3.0",
    "p-retry": "^8.0.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  }
}
