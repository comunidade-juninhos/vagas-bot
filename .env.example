PORT=3000
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/vagas-bot

# Shared secret used by the worker when posting jobs.created to the bots service.
WEBHOOK_URL=http://localhost:3000/webhooks/jobs
WEBHOOK_SECRET=change-me
WEBHOOK_MAX_JOBS_PER_RUN=50
WEBHOOK_DELAY_MS=1000
WEBHOOK_RETRIES=6
WEBHOOK_RETRY_DELAY_MS=1000
JOB_SOURCES=meupadrinho,remotar,gupy
MEUPADRINHO_MAX_PAGES=10
MEUPADRINHO_CARGO_FILTERS=QA,BACKEND,FRONTEND,FULLSTACK,MOBILE,DEVOPS,DADOS,CX,SECURITY,IA,PRODUTO
REMOTAR_MAX_PAGES=3
GUPY_MAX_PAGES_PER_KEYWORD=1

# Notification window. The worker still scrapes outside this window, but queues webhook delivery.
NOTIFICATION_QUIET_HOURS_ENABLED=true
NOTIFICATION_START_HOUR=6
NOTIFICATION_END_HOUR=24
NOTIFICATION_TIME_ZONE=America/Sao_Paulo

# WhatsApp / Baileys
WHATSAPP_ENABLED=false
AUTH_METHOD=code
MOBILE_NUMBER=5511999999999
WHATSAPP_GROUP_ID=120000000000000000@g.us

# Discord
DISCORD_ENABLED=true
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=
